@{
    ViewData["Title"] = "Index";
   // Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>ExamSys - Admin Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  @*   <link rel="stylesheet" href="../css/admin.css"> *@
    <link href="~/css/admin.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-header">
            <i class="fas fa-graduation-cap"></i>
            <h2>ExamSys</h2>
        </div>
        <nav class="sidebar-nav">
            <a href="#" class="nav-item active"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
            <a href="#" class="nav-item"><i class="fas fa-edit"></i> Manage Exams</a>
            <a href="#" class="nav-item"><i class="fas fa-question-circle"></i> Question Bank</a>
            <a href="#" class="nav-item"><i class="fas fa-users"></i> Students</a>
            <a href="#" class="nav-item"><i class="fas fa-chart-bar"></i> Results</a>
        </nav>
        <button class="logout-btn" onclick="logout()">
            <i class="fas fa-sign-out-alt"></i> Logout
        </button>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main">
        <!-- HEADER -->
        <div class="header">
            <div class="header-left">
                <button class="menu-toggle"><i class="fas fa-bars"></i></button>
                <div class="header-greeting">
                    <h3>Hi, Teacher 👋</h3>
                    <p>Welcome back to your dashboard</p>
                </div>
            </div>
            <div class="header-right">
                <button class="notification-btn"><i class="fas fa-bell"></i></button>
                <button class="profile-btn" onclick="logout()">
                    <i class="fas fa-user-circle"></i>
                </button>
            </div>
        </div>

        <!-- STATS CARDS -->
        <div class="stats-grid">
            <div class="stat-card primary">
                <div class="stat-icon"><i class="fas fa-clipboard-list"></i></div>
                <div class="stat-content">
                    <h2 id="totalExams">5</h2>
                    <p>Total Exams</p>
                </div>
            </div>
            <div class="stat-card success">
                <div class="stat-icon"><i class="fas fa-question"></i></div>
                <div class="stat-content">
                    <h2 id="totalQuestions">120</h2>
                    <p>Total Questions</p>
                </div>
            </div>
            <div class="stat-card warning">
                <div class="stat-icon"><i class="fas fa-users"></i></div>
                <div class="stat-content">
                    <h2 id="totalStudents">80</h2>
                    <p>Total Students</p>
                </div>
            </div>
            <div class="stat-card info">
                <div class="stat-icon"><i class="fas fa-calendar-check"></i></div>
                <div class="stat-content">
                    <h2 id="examsConducted">18</h2>
                    <p>Exams Conducted</p>
                </div>
            </div>
        </div>

        <!-- MAIN DASHBOARD -->
        <div class="dashboard-grid">
            <!-- MANAGE EXAMS -->
            <div class="dashboard-card">
                <div class="card-header">
                    <h3><i class="fas fa-edit"></i> Manage Exams</h3>
                    <button class="btn-primary" onclick="createExam()">
                        <i class="fas fa-plus"></i> Create New Exam
                    </button>
                </div>
                <div class="exam-list" id="examList">
                    <!-- Dynamic content loaded by JS -->
                </div>
            </div>

            <!-- RECENT ACTIVITY -->
            <div class="dashboard-card side-panel">
                <div class="card-header">
                    <h3><i class="fas fa-history"></i> Recent Activity</h3>
                </div>
                <div class="activity-list" id="recentActivity">
                    <div class="activity-item">
                        <span class="activity-avatar">TP</span>
                        <div class="activity-content">
                            <strong>Tanishka Patil</strong> completed DBMS exam
                            <span class="activity-score">68%</span>
                        </div>
                    </div>
                    <div class="activity-item">
                        <span class="activity-avatar">R</span>
                        <div class="activity-content">
                            <strong>Rahul Sharma</strong> completed Java exam
                            <span class="activity-score">74%</span>
                        </div>
                    </div>
                    <div class="activity-item">
                        <span class="activity-avatar">A</span>
                        <div class="activity-content">
                            <strong>Anjali K.</strong> completed C Programming
                            <span class="activity-score">81%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- QUESTION BANK -->
        <div class="dashboard-card full-width">
            <div class="card-header">
                <h3><i class="fas fa-database"></i> Question Bank</h3>
            </div>
            <div class="question-bank-grid" id="questionBank">
                <!-- Dynamic content loaded by JS -->
            </div>
        </div>
    </div>

@*     <script src="../js/admin.js"></script> *@
</body>
</html>
