@model IEnumerable<Online_Exam_system.Models.User>

@{
    // ViewData["Title"] = "Index";
    Layout = null;
}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>ExamSys - Login</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="~/css/auth.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <div class="auth-container">
        <!-- Left Background -->
        <div class="auth-left">
            <div class="auth-brand">
                <i class="fas fa-graduation-cap"></i>
                <h1>ExamSys</h1>
                <p>Your ultimate learning platform</p>
            </div>
            <div class="auth-features">
                <div class="feature-item">
                    <i class="fas fa-chart-line"></i>
                    <span>Real-time Analytics</span>
                </div>
                <div class="feature-item">
                    <i class="fas fa-shield-alt"></i>
                    <span>Secure & Private</span>
                </div>
                <div class="feature-item">
                    <i class="fas fa-mobile-alt"></i>
                    <span>Mobile Friendly</span>
                </div>
            </div>
        </div>

        <!-- Right Form -->
        <div class="auth-right">
            <div class="auth-form">
                <div class="form-header">
                    <h2 id="loginTitle">Welcome Back!</h2>
                    <p >Sign in to your account</p>
                </div>

                <!-- ROLE SELECTOR -->
               @*  <div class="role-selector">
                    <div class="role-tabs">
                        <button type="button" class="role-tab active" data-role="student" onclick="switchRole('student')">
                            <i class="fas fa-user-graduate"></i>
                            <span>Student</span>
                        </button>
                        <button type="button" class="role-tab" data-role="admin" onclick="switchRole('admin')">
                            <i class="fas fa-chalkboard-teacher"></i>
                            <span>Admin</span>
                        </button>
                    </div>
                </div> *@

               @*  <form id="loginForm" class="auth-form-group">
                    <div class="input-group">
                        <i class="fas fa-envelope input-icon"></i>
                        <input type="email" id="email" placeholder="Email" required>
                    </div>

                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" id="password" placeholder="Password" required>
                        <div class="password-toggle" onclick="togglePassword()">
                            <i class="fas fa-eye" id="toggleIcon"></i>
                        </div>
                    </div>

                    <div class="form-options">
                        <label class="checkbox-container">
                            <input type="checkbox" id="rememberMe">
                            Remember me
                        </label>
                    </div>

                    <button type="submit" class="btn-primary btn-large">
                        <i class="fas fa-sign-in-alt"></i>
                        <span id="loginBtnText">Sign In as Student</span>
                    </button>
                </form> *@
                <form asp-controller="Login" asp-action="Login" method="post" id="loginForm" class="auth-form-group">
                    <div class="input-group">
                        <i class="fas fa-envelope input-icon"></i>
                        <input type="email" name="Email" placeholder="Email" required />
                    </div>

                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="Password" placeholder="Password" required />
                    </div>

                    <button type="submit" class="btn-primary btn-large">
                        Sign In
                    </button>
                </form>

               @*  <button class="btn-google" onclick="loginWithGoogle()">
                    <i class="fab fa-google"></i>
                    Continue with Google
                </button> *@

                <div class="auth-footer">
                    <p>Don't have an account? <a asp-controller="Register" asp-action="index" class="link-primary">Sign up here</a></p>
                </div>

                <div id="msg" class="message"></div>
            </div>
        </div>
    </div>

    @*    <script src="../js/auth.js"></script> *@
    <script src="~/js/auth.js"></script>
</body>
</html>
