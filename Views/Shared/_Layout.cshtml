@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html>
<head>
    <title>ExamSys Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
   @*  <link href="~/css/auth.css" rel="stylesheet" /> *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background-color: #f4f6f9;

        }

        .auth-brand {
            text-align: center;
            z-index: 2;
            position: relative;
        }

            .auth-brand i {
                font-size: 4rem;
                color: rgba(255,255,255,0.2);
                margin-bottom: 20px;
            }
        .sidebar {
            width: 240px;
            height: 100vh;
            position: fixed;
            /* background: linear-gradient(180deg, #5f2eea, #7b5cff); */
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding-top: 20px;
            color: white;
        }

            .sidebar h3 {
                text-align: center;
                margin-bottom: 30px;
            }

            .sidebar a {
                padding: 12px 20px;
                display: block;
                color: white;
                text-decoration: none;
                font-size: 15px;
            }

                .sidebar a:hover {
                    background: rgba(255,255,255,0.2);
                }

/*         .topbar {
            margin-left: 240px;
            height: 60px;
            background: white;
            padding: 15px 30px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        } */

        .topbar {
            position: fixed;
            top: 0;
            left: 240px; /* same as sidebar width */
            right: 0; /* stretch to right */
            height: 60px;
            background: white;
            padding: 15px 30px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000; /* stay above content */
        }
        .content {
            margin-left: 240px;
            padding: 30px;
        }

        .card-box {
            border-radius: 12px;
            padding: 20px;
            color: white;
            margin-bottom: 20px;
        }

        .card-purple {
            background: linear-gradient(45deg, #6a11cb, #2575fc);
        }

        .card-green {
            background: linear-gradient(45deg, #11998e, #38ef7d);
        }

        .card-orange {
            background: linear-gradient(45deg, #f7971e, #ffd200);
        }
    </style>
</head>

<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="auth-brand">
            <i class="fas fa-graduation-cap"></i>
            <h3>ExamSys</h3>
        </div>

        <a asp-controller="Home" asp-action="Index">
            <i class="fas fa-home"></i> Dashboard
        </a>

        @if (Context.Session.GetString("UserRole") == "admin")
        {

            <a asp-controller="Student" asp-action="Index">
                <i class="fas fa-users"></i> Student List
            </a>

            <a asp-controller="Exam" asp-action="index">
                <i class="fas fa-plus"></i> Create Exam
            </a>

            <a asp-controller="Result" asp-action="Index">
                <i class="fas fa-chart-bar"></i> View Results
            </a>

        }

        @if (Context.Session.GetString("UserRole") == "student")
        {
            <a asp-controller="Exam" asp-action="AvailableExams">
                <i class="fas fa-book"></i> Available Exams
            </a>

            <a asp-controller="MyResults" asp-action="MyResults">
                <i class="fas fa-file-alt"></i> My Results
            </a>
        }

        <hr style="color:white;" />

        <a asp-controller="Login" asp-action="Logout">
            <i class="fas fa-sign-out-alt"></i> Logout
        </a>
    </div>

    <!-- Top Bar -->
    <div class="topbar">
        <div>
            Welcome, <strong>@Context.Session.GetString("UserName")</strong>
        </div>

        <div>
            Role: <strong>@Context.Session.GetString("UserRole")</strong>
        </div>
    </div>

    <!-- Main Content -->
    <div class="content">
        @RenderBody()
    </div>

</body>
</html>